# Copy to .streamlit/secrets.toml (git-ignored) for local dev, or paste into
# Streamlit Community Cloud → App → Settings → Secrets.
#
# --- AMD engine (OpenAI-compatible) --------------------------------------
# Live now on an AMD Radeon PRO W7900 (RDNA 3 · ROCm); the same keys point at an
# AMD Instinct MI300X when that host is used instead (just change host/ports).
#
# Writer + Fact-checker + Translator — Google Gemma 3:
#   W7900: llama.cpp (ROCm/HIP) :8000   ·   MI300X: vLLM :8000
AMD_BASE_URL  = "http://YOUR_AMD_HOST:8000/v1"
AMD_MODEL     = "gemma-3-27b-it"
AMD_API_KEY   = "your-endpoint-token"
# Researcher — real semantic retrieval:
#   W7900: bge-m3 :7860   ·   MI300X: Google EmbeddingGemma :8001
AMD_EMBED_URL = "http://YOUR_AMD_HOST:7860/v1"
AMD_EMBED_MODEL = "bge-m3"
# Image agent — featured image (SDXL-Turbo):
#   W7900: :8501   ·   MI300X: :8002
AMD_IMAGE_URL = "http://YOUR_AMD_HOST:8501"

# --- Optional: Fireworks AI (alternative fully-hosted engine) ------------
# Writer + Fact-checker on gpt-oss-120b; Researcher on qwen3-embedding-8b.
# FIREWORKS_API_KEY = "fw-..."
