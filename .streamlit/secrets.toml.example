# Copy to .streamlit/secrets.toml (git-ignored) for local dev, or paste into
# Streamlit Community Cloud → App → Settings → Secrets.
#
# --- AMD engine (all on AMD Instinct MI300X, OpenAI-compatible) -----------
# Writer + Fact-checker (vLLM chat) — Google Gemma 3:
AMD_BASE_URL  = "http://YOUR_MI300X_HOST:8000/v1"
AMD_MODEL     = "gemma-3-4b-it"
AMD_API_KEY   = "your-endpoint-token"
# Researcher — real semantic retrieval (Google EmbeddingGemma):
AMD_EMBED_URL = "http://YOUR_MI300X_HOST:8001/v1"
AMD_EMBED_MODEL = "embeddinggemma"
# Image agent — featured image (SDXL):
AMD_IMAGE_URL = "http://YOUR_MI300X_HOST:8002"

# --- Optional: hosted LLM API (alternative live engine) ------------------
# ANTHROPIC_API_KEY = "sk-ant-..."
