# Copy to .streamlit/secrets.toml (git-ignored) for local dev, or paste into
# Streamlit Community Cloud → App → Settings → Secrets.
#
# --- AMD engine (vLLM on AMD Instinct MI300X, OpenAI-compatible) ----------
# Enables the "AMD · MI300X" inference engine for Writer + Fact-checker.
AMD_BASE_URL = "http://YOUR_MI300X_HOST:8000/v1"
AMD_MODEL    = "qwen2.5-7b-instruct"
AMD_API_KEY  = "your-vllm-endpoint-token"

# --- Optional: hosted LLM API (alternative live engine) ------------------
# ANTHROPIC_API_KEY = "sk-ant-..."
